{
  "compilerOptions": {
    "lib": [
      "esnext",
      "DOM"
    ],
    "outDir": "dist",
    "target": "es2018",
    "declaration": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "strict": false,
    "module": "esnext",
    "moduleResolution": "node",
    "strictNullChecks": true,
    "resolveJsonModule": true,
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules",
    "build",
    "dist",
    "example",
    "rollup.config.js"
  ]
}